<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hzk.backend.mapper.SysUserMapper">

    <select id="login" resultType="com.hzk.backend.pojo.SysUser">

        SELECT id, username, password,
        role, remark, create_time as createTime, status
        FROM sys_user

        WHERE username = #{username}
        AND password = #{password}
    </select>

    <!--  插入返回主键 主键对应的id 存在SysUser.id -->
    <insert id="insert" parameterType="com.hzk.backend.pojo.SysUser">
        INSERT INTO sys_user (username, password, role, remark, create_time, status)
        VALUES(#{username}, #{password}, #{role}, #{remark}, now(), 1)
    </insert>

    <!--  更新功能  -->
    <update id="update">
        UPDATE sys_user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="role != null and role != ''">
                role = #{role},
            </if>
            <if test="remark != null and remark != ''">
                remark = #{remark},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!--  删除功能  -->
    <delete id="deleteById">
        DELETE from sys_user WHERE id = #{id}
    </delete>

    <!--  搜索功能  -->
    <select id="search" resultType="com.hzk.backend.pojo.SysUser">
        SELECT id, username, password,
        role, remark, create_time as createTime, status
        FROM sys_user

        <where>
            <if test="name != null and name != ''">
                AND admin_name LIKE concat('%', #{name}, '%')
            </if>

            <if test="btime != null and btime != ''">
                AND create_time &gt;= #{btime}
            </if>

            <if test="etime != null and etime !=''">
                AND create_time &lt;= #{etime}
            </if>

            <if test="role != null and role != ''">
                AND role = #{role}
            </if>

            <if test="status != null">
                AND status = #{status}
            </if>
        </where>

        LIMIT  #{start}, #{end}
    </select>


